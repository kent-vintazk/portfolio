# Copy this file to `.env.local` and fill in the values.
# Restart `npm run dev` after editing.

# ── Resend (contact form) ──
# 1. Create a free account at https://resend.com (3000 emails/mo free)
# 2. Create an API key at https://resend.com/api-keys
# 3. Paste it below
RESEND_API_KEY=re_MHoeLJTw_7c7U6uXNL3ZHg9U7uHn4db4w

# Optional: override the sender address.
# Default is onboarding@resend.dev (Resend's test sender — can only send to
# the email you signed up with). To send to any address, verify a custom
# domain at https://resend.com/domains and set something like:
#   RESEND_FROM=Portfolio <hello@yourdomain.com>
# RESEND_FROM=Portfolio Contact <onboarding@resend.dev>

# Where contact-form submissions should be delivered
CONTACT_TO_EMAIL=kendric